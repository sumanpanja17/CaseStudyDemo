{
  "name": "casestudydemo",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap/cds": "^9.7.1",
    "express": "^4",
    "sqlite": "^5.1.1"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sapui5/ts-types-esm": "^1.145.0",
    "@types/node": "^25.3.0",
    "cds-plugin-ui5": "^0.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-employee": "cds watch --open employee/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project": "cds watch --open project/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-learning": "cds watch --open learning/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      }
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employee",
    "app/project",
    "app/project1",
    "app/learning",
    "app/learning"
  ],
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
